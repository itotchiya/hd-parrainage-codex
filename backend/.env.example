APP_NAME="HD Parrainage API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hd_parrainage_dev
DB_USERNAME=hd_parrainage
DB_PASSWORD=hd_parrainage_local

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=localhost:5175,127.0.0.1:5175,localhost:8081,127.0.0.1:8081
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
FRONTEND_URL=http://localhost:5175

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=hd_parrainage

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@mail.mbouf.site"
MAIL_FROM_NAME="HD Parrainage"

RESEND_API_KEY=
RESEND_FROM_ADDRESS="noreply@mail.mbouf.site"

SENTRY_LARAVEL_DSN=

IACRM_BASE_URL=
IACRM_AUTH_MODE=token
IACRM_TOKEN=
IACRM_CLIENT_ID=
IACRM_CLIENT_SECRET=
IACRM_WEBHOOK_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
